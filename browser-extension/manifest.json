{
  "manifest_version": 3,
  "name": "Tiny DFR Browser Helper",
  "version": "1.0",
  "description": "Browser extension for tiny-dfr touchbar integration",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tiny DFR Browser Helper"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
} 